{
  "name": "boilerplate",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --elide-lines 0 --filter=api dev & bun run --elide-lines 0 --filter=web dev",
    "dev:api": "bun run --elide-lines 0 --filter=api dev",
    "dev:web": "bun run --elide-lines 0 --filter=web dev",
    "dev:docs": "bun run --elide-lines 0 --filter=./apps/docs start",
    "build": "bun run build:packages && bun run build:apps",
    "build:packages": "bun run --filter='./packages/*' build",
    "build:apps": "bun run --filter='./apps/api' --filter='./apps/web' --filter='./packages/*' build",
    "build:docs": "bun run --filter=./apps/docs build",
    "typecheck": "bun run --filter='*' typecheck",
    "lint": "bun run --filter='*' lint",
    "clean": "bun run --filter='*' clean"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "turbo": "^2.3.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "typescript": "^5.8.0"
  },
  "packageManager": "pnpm@10.33.0"
}
