# Environment variables — copy to .env.development (local) or .env.production (server)

# ── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database (MySQL) ─────────────────────────────────────────────────────────
DATABASE_URL=mysql://root:password@localhost:3306/app_db
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=app_db
# DB_SSL=false     # set to true for production with SSL

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_random_256bit_secret
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_IN=7d

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=100

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ── Security ──────────────────────────────────────────────────────────────────
ENABLE_CSP=true

# ── Frontend ─────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3000
VITE_APP_NAME=My App
